<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for(:title) { "Sistema de TCCs" } %> — GestãoTCC</title>

  <!-- Bootstrap 5 + Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <!-- Inter Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* ═══════════════════════════════ Tokens ═══════════════════════════════ */
    :root {
      --navy:          #0F2347;
      --navy-mid:      #1B3A6B;
      --blue-accent:   #2F7AEA;
      --blue-light:    #EBF3FF;
      --bg:            #F0F4F8;
      --surface:       #FFFFFF;
      --border:        #E2E8F0;
      --text:          #1E293B;
      --muted:         #64748B;
      --sidebar-text:  #94A8BF;
      --sidebar-hover: rgba(255,255,255,.08);

      /* Status palette — used everywhere: badges, charts, selects */
      --s-elaboracao:  #3B82F6;  /* azul   */
      --s-enviado:     #F59E0B;  /* âmbar  */
      --s-aprovado:    #16A34A;  /* verde  */
      --s-reprovado:   #DC2626;  /* vermelho */
    }

    /* ══════════════════════════ Base ══════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      display: flex;
      min-height: 100vh;
    }

    /* ══════════════════════════ Sidebar ═══════════════════════════════════ */
    .sidebar {
      width: 260px;
      min-height: 100vh;
      background: var(--navy);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0;
      z-index: 100;
      transition: width .25s ease;
    }

    .sidebar-brand {
      padding: 28px 24px 20px;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .sidebar-brand .brand-name {
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.3px;
      display: block;
    }

    .sidebar-brand .brand-sub {
      font-size: .72rem;
      color: var(--sidebar-text);
      font-weight: 400;
      letter-spacing: .5px;
      text-transform: uppercase;
    }

    .sidebar nav { padding: 16px 0; flex: 1; }

    .nav-section {
      padding: 10px 24px 4px;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: 1.2px;
      color: var(--sidebar-text);
      text-transform: uppercase;
    }

    .nav-link-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 24px;
      color: var(--sidebar-text);
      text-decoration: none;
      font-size: .875rem;
      font-weight: 500;
      border-radius: 0;
      transition: background .15s, color .15s;
      position: relative;
    }

    .nav-link-item:hover {
      background: var(--sidebar-hover);
      color: #fff;
    }

    .nav-link-item.active {
      background: var(--sidebar-hover);
      color: #fff;
    }

    .nav-link-item.active::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--blue-accent);
      border-radius: 0 2px 2px 0;
    }

    .nav-link-item .bi { font-size: 1rem; opacity: .85; }

    .sidebar-footer {
      padding: 16px 24px;
      border-top: 1px solid rgba(255,255,255,.08);
      font-size: .72rem;
      color: var(--sidebar-text);
    }

    /* ══════════════════════════ Main Content ══════════════════════════════ */
    .main-wrapper {
      margin-left: 260px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 32px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
    }

    .topbar-meta {
      font-size: .8rem;
      color: var(--muted);
    }

    .main-content {
      padding: 32px;
      flex: 1;
    }

    /* ══════════════════════════ Page Header ═══════════════════════════════ */
    .page-header {
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .page-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--navy);
      margin: 0;
    }

    /* ══════════════════════════ Cards ═════════════════════════════════════ */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      box-shadow: 0 1px 3px rgba(0,0,0,.04);
    }

    .card-header {
      background: transparent;
      border-bottom: 1px solid var(--border);
      padding: 16px 20px;
      font-weight: 600;
      font-size: .9rem;
      color: var(--text);
    }

    .stat-card {
      padding: 24px;
      border-radius: 12px;
      border: none;
    }

    .stat-card .stat-label {
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .stat-card .stat-value {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1;
      color: var(--navy);
    }

    .stat-card .stat-icon {
      width: 44px; height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
    }

    /* ══════════════════════════ Tables ════════════════════════════════════ */
    .table-card {
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .table { margin: 0; font-size: .875rem; }

    .table thead th {
      background: #F8FAFC;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .6px;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding: 12px 16px;
    }

    .table tbody td {
      padding: 12px 16px;
      vertical-align: middle;
      border-color: var(--border);
    }

    .table tbody tr:hover { background: #FAFCFF; }

    /* ══════════════════════════ Status Badges ═════════════════════════════ */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .2px;
    }

    .badge-elaboracao { background: #EFF6FF; color: var(--s-elaboracao); }
    .badge-enviado    { background: #FFFBEB; color: var(--s-enviado); }
    .badge-aprovado   { background: #F0FDF4; color: var(--s-aprovado); }
    .badge-reprovado  { background: #FEF2F2; color: var(--s-reprovado); }

    /* ══════════════════════════ Forms ═════════════════════════════════════ */
    .form-label {
      font-size: .8rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 5px;
    }

    .form-control, .form-select {
      border: 1px solid var(--border);
      border-radius: 7px;
      font-size: .875rem;
      padding: 9px 12px;
      color: var(--text);
      transition: border-color .15s, box-shadow .15s;
    }

    .form-control:focus, .form-select:focus {
      border-color: var(--blue-accent);
      box-shadow: 0 0 0 3px rgba(47,122,234,.15);
      outline: none;
    }

    /* ══════════════════════════ Buttons ═══════════════════════════════════ */
    .btn-primary-custom {
      background: var(--navy-mid);
      color: #fff;
      border: none;
      border-radius: 7px;
      padding: 9px 18px;
      font-size: .875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s;
    }

    .btn-primary-custom:hover { background: var(--blue-accent); color: #fff; }

    .btn-outline-custom {
      background: transparent;
      color: var(--navy-mid);
      border: 1.5px solid var(--border);
      border-radius: 7px;
      padding: 8px 16px;
      font-size: .875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-outline-custom:hover {
      border-color: var(--navy-mid);
      background: var(--blue-light);
      color: var(--navy-mid);
    }

    /* ══════════════════════════ Search bar ════════════════════════════════ */
    .search-bar {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .search-input-wrap {
      position: relative;
      flex: 1;
      min-width: 200px;
    }

    .search-input-wrap .bi {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: .9rem;
    }

    .search-input-wrap input {
      padding-left: 36px !important;
    }

    /* ══════════════════════════ Alerts / Flash ════════════════════════════ */
    .flash-notice {
      background: #F0FDF4;
      border: 1px solid #BBF7D0;
      color: #15803D;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: .875rem;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .flash-alert {
      background: #FEF2F2;
      border: 1px solid #FECACA;
      color: #B91C1C;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: .875rem;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* ══════════════════════════ Empty state ═══════════════════════════════ */
    .empty-state {
      text-align: center;
      padding: 56px 24px;
      color: var(--muted);
    }

    .empty-state .bi {
      font-size: 2.5rem;
      display: block;
      margin-bottom: 12px;
      opacity: .4;
    }

    .empty-state p {
      font-size: .9rem;
      margin: 0;
    }

    /* ══════════════════════════ File upload area ══════════════════════════ */
    .file-upload-area {
      border: 2px dashed var(--border);
      border-radius: 10px;
      padding: 24px;
      text-align: center;
      cursor: pointer;
      transition: border-color .15s, background .15s;
    }

    .file-upload-area:hover {
      border-color: var(--blue-accent);
      background: var(--blue-light);
    }

    .file-upload-area .bi { font-size: 2rem; color: var(--muted); }
    .file-upload-area p { font-size: .8rem; color: var(--muted); margin: 8px 0 0; }
    .file-upload-area input[type=file] { display: none; }

    /* ══════════════════════════ Responsive ════════════════════════════════ */
    @media (max-width: 768px) {
      .sidebar { width: 0; overflow: hidden; }
      .main-wrapper { margin-left: 0; }
    }
  </style>
</head>
<body>
  <!-- ────────────── Sidebar ────────────── -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <span class="brand-name">
        <i class="bi bi-mortarboard-fill me-2" style="color: var(--blue-accent)"></i>GestãoTCC
      </span>
      <span class="brand-sub">Sistema Acadêmico</span>
    </div>

    <nav>
      <div class="nav-section">Principal</div>
      <%= link_to dashboard_path, class: "nav-link-item #{active_nav?('dashboard')}" do %>
        <i class="bi bi-speedometer2"></i> Dashboard
      <% end %>
      <%= link_to tccs_path, class: "nav-link-item #{active_nav?('tccs')}" do %>
        <i class="bi bi-file-earmark-text"></i> TCCs
      <% end %>

      <div class="nav-section" style="margin-top: 8px">Pessoas</div>
      <%= link_to alunos_path, class: "nav-link-item #{active_nav?('alunos')}" do %>
        <i class="bi bi-person-badge"></i> Alunos
      <% end %>
      <%= link_to professores_path, class: "nav-link-item #{active_nav?('professores')}" do %>
        <i class="bi bi-person-workspace"></i> Professores
      <% end %>

      <div class="nav-section" style="margin-top: 8px">Estrutura</div>
      <%= link_to cursos_path, class: "nav-link-item #{active_nav?('cursos')}" do %>
        <i class="bi bi-book"></i> Cursos
      <% end %>
      <%= link_to departamentos_path, class: "nav-link-item #{active_nav?('departamentos')}" do %>
        <i class="bi bi-building"></i> Departamentos
      <% end %>
      <%= link_to unidades_academicas_path, class: "nav-link-item #{active_nav?('unidades_academicas')}" do %>
        <i class="bi bi-bank"></i> Unidades Acadêmicas
      <% end %>
    </nav>

    <div class="sidebar-footer">
      <i class="bi bi-circle-fill me-1" style="color: #22C55E; font-size: .5rem"></i>
      API: <%= ENV.fetch("API_BASE_URL", "http://127.0.0.1:8000/api") %>
    </div>
  </aside>

  <!-- ────────────── Main ────────────── -->
  <div class="main-wrapper">
    <header class="topbar">
      <span class="topbar-title"><%= yield :topbar_title %></span>
      <span class="topbar-meta">
        <i class="bi bi-calendar3 me-1"></i><%= Time.now.strftime("%d/%m/%Y") %>
      </span>
    </header>

    <main class="main-content">
      <% if notice.present? %>
        <div class="flash-notice">
          <i class="bi bi-check-circle-fill"></i> <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="flash-alert">
          <i class="bi bi-exclamation-triangle-fill"></i> <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Drag-and-drop file upload visual
    document.querySelectorAll('.file-upload-area').forEach(area => {
      area.addEventListener('click', () => area.querySelector('input').click());
      area.addEventListener('dragover', e => { e.preventDefault(); area.style.borderColor = 'var(--blue-accent)'; });
      area.addEventListener('dragleave',   () => area.style.borderColor = '');
      area.addEventListener('drop', e => {
        e.preventDefault();
        area.style.borderColor = '';
        const input = area.querySelector('input');
        if (input && e.dataTransfer.files.length) {
          input.files = e.dataTransfer.files;
          area.querySelector('.file-name') && (area.querySelector('.file-name').textContent = e.dataTransfer.files[0].name);
        }
      });
      const input = area.querySelector('input');
      if (input) input.addEventListener('change', () => {
        const label = area.querySelector('.file-name');
        if (label && input.files.length) label.textContent = input.files[0].name;
      });
    });
  </script>
  <%= yield :scripts %>
</body>
</html>
