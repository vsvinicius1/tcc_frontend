<% content_for :title, "Alunos" %>
<% content_for :topbar_title, "Alunos Cadastrados" %>

<div class="page-header">
  <h1 class="page-title">Alunos</h1>
  <span class="badge bg-primary rounded-pill px-3" style="font-size:.8rem">
    <%= @alunos.size %> registros
  </span>
</div>

<!-- Search -->
<div class="card p-3 mb-4">
  <%= form_with url: alunos_path, method: :get, local: true do |f| %>
    <div class="search-bar">
      <div class="search-input-wrap">
        <i class="bi bi-search"></i>
        <%= f.text_field :search, value: @search, placeholder: "Buscar por nome, matrícula, e-mail…",
            class: "form-control" %>
      </div>
      <button type="submit" class="btn-primary-custom">
        <i class="bi bi-search me-1"></i> Buscar
      </button>
      <% if @search.present? %>
        <%= link_to alunos_path, class: "btn-outline-custom" do %>
          <i class="bi bi-x-lg"></i> Limpar
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Tabela -->
<div class="card table-card">
  <% if @alunos.empty? %>
    <div class="empty-state">
      <i class="bi bi-person-x"></i>
      <p>Nenhum aluno encontrado.</p>
    </div>
  <% else %>
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Matrícula</th>
            <th>E-mail</th>
            <th>Curso</th>
          </tr>
        </thead>
        <tbody>
          <% @alunos.each_with_index do |aluno, i| %>
            <tr>
              <td class="text-muted" style="font-size:.78rem"><%= i + 1 %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div style="width:32px; height:32px; border-radius:50%; background: #EBF3FF;
                    display:flex; align-items:center; justify-content:center;
                    font-weight:700; font-size:.75rem; color:#2F7AEA; flex-shrink:0">
                    <%= (aluno["nome"] || "#{aluno["first_name"]} #{aluno["last_name"]}".strip).first.upcase %>
                  </div>
                  <span class="fw-500">
                    <%= aluno["nome"] || "#{aluno["first_name"]} #{aluno["last_name"]}".strip %>
                  </span>
                </div>
              </td>
              <td class="text-muted"><%= aluno["matricula"] || "—" %></td>
              <td class="text-muted"><%= aluno["email"] || "—" %></td>
              <td>
                <% curso = @cursos.find { |c| c["id"] == aluno["curso"] } %>
                <%= curso ? curso["nome"] : (aluno["curso_nome"] || "—") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
